{
  "manifest_version": 3,
  "name": "Twitch Random Streamer",
  "version": "1.0.0",
  "description": "Открывает случайного стримера на Twitch по заданным фильтрам",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.twitch.tv/*",
    "https://id.twitch.tv/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
